[Desktop Entry]
Version=1.0
Type=Application
Name=AnySort
Comment=Robotic Grasping Pipeline
Exec=bash -c "cd %k/.. && xhost +local:docker > /dev/null 2>&1 && docker compose -f docker/docker-compose.yml up -d && docker compose -f docker/docker-compose.yml exec graspgen bash -c 'source /opt/GraspGen/.venv/bin/activate && cd /ros2_ws/app && python anysort.py'"
Icon=utilities-terminal
Terminal=false
Categories=Science;Robotics;
