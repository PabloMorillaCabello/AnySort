# =============================================================================
# GraspGen Thesis - .gitignore
# =============================================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
.eggs/
*.so

# --- Virtual environments ---
venv/
.venv/
env/

# --- AI Model weights (stored in Docker named volume, not in repo) ---
*.onnx
*.pt
*.pth
*.bin
*.safetensors
*.weights

# --- Data (captured during experiments) ---
data/rgb/*.png
data/rgb/*.jpg
data/depth/*.png
data/depth/*.npy
data/masks/*.png
data/grasp_poses/*.json
data/grasp_poses/*.npy
data/pointcloud/*.ply
data/pointcloud/*.npy
data/depth_aligned/*.npy
data/depth_aligned/*.png
# --- Results ---
results/*
!results/.gitkeep

# --- Orbbec SDK (cloned at Docker build, not tracked) ---
OrbbecSDK_v2/
orbbec_examples/

# --- Docker ---
docker/.env

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~
.project
.cproject

# --- OS ---
.DS_Store
Thumbs.db

# --- Jupyter ---
.ipynb_checkpoints/

# --- Logs ---
*.log
log/

# --- Secrets ---
.env
*.key
*.pem

# --- Claude Code ---
.claude/
CLAUDE.md.original.md

# --- Obsidian (note-taking app) ---
.obsidian/

# --- App runtime state (auto-generated, not for sharing) ---
app/pipeline_positions.json
app/pipeline_roi.json
app/Log/

# --- Log files ---
*.log.txt
scripts/Log/
data/Log/

# --- Stray data files ---
data/*.json