# =============================================================================
# Environment Variables for GraspGen Thesis
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# Hugging Face token for downloading model weights (SAM3 + GraspGen)
# 1. Create account at https://huggingface.co
# 2. Request access to facebook/sam3 model
# 3. Request access to adithyamurali/GraspGenModels
# 4. Generate token at https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# Display for GUI forwarding (RViz, Meshcat visualization)
DISPLAY=:0

# CUDA compute capability for PointNet++ compilation
# Set ONLY your GPU to speed up build time:
#   RTX 3060/3070/3080/3090 = 8.6
#   RTX 4060/4070/4080/4090 = 8.9
#   A100 = 8.0  |  H100 = 9.0
TORCH_CUDA_ARCH_LIST=8.6
